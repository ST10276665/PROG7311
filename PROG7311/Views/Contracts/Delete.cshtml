@model PROG7311.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<div class="page-header">
    <h2>Delete Contract</h2>
    <p>Are you sure you want to delete this contract?</p>
</div>

<div class="card border-0 shadow-sm p-4" style="max-width: 600px;">
    <dl class="row">
        <dt class="col-sm-3">Client</dt>
        <dd class="col-sm-9">@Model.Client.Name</dd>

        <dt class="col-sm-3">Service Level</dt>
        <dd class="col-sm-9">@Model.ServiceLevel</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ContractId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>