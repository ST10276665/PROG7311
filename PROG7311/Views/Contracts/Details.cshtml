@model PROG7311.Models.Contract
@{
    ViewData["Title"] = "Contract Details";
}

<div class="page-header">
    <h2>Contract Details</h2>
    <p>Full contract information and service requests</p>
</div>

<div class="card border-0 shadow-sm p-4 mb-4" style="max-width: 700px;">
    <dl class="row mb-0">
        <dt class="col-sm-3">Client</dt>
        <dd class="col-sm-9">@Model.Client.Name</dd>

        <dt class="col-sm-3">Service Level</dt>
        <dd class="col-sm-9">@Model.ServiceLevel</dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            <span class="badge @(Model.Status == "Active" ? "bg-success" : Model.Status == "Expired" ? "bg-danger" : Model.Status == "On Hold" ? "bg-warning text-dark" : "bg-secondary")">
                @Model.Status
            </span>
        </dd>

        <dt class="col-sm-3">Signed Agreement</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <a href="@Model.SignedAgreementPath" target="_blank" class="btn btn-sm btn-outline-success">Download PDF</a>
            }
            else
            {
                <span class="text-muted small">No file uploaded</span>
            }
        </dd>
    </dl>
</div>

<h5 class="mb-3">Service Requests</h5>
<div class="card border-0 shadow-sm">
    @if (Model.ServiceRequests.Any())
    {
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Description</th>
                    <th>Cost</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sr in Model.ServiceRequests)
                {
                    <tr>
                        <td>@sr.Description</td>
                        <td>R @sr.Cost.ToString("N2")</td>
                        <td><span class="badge bg-secondary">@sr.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="p-4 text-muted small">No service requests linked to this contract.</div>
    }
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-outline-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>