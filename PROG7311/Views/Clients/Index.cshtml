@model IEnumerable<PROG7311.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2>Clients</h2>
        <p>Manage TechMove's client records</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ New Client</a>
</div>

<div class="card border-0 shadow-sm">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Contact Details</th>
                <th>Region</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model)
            {
                <tr>
                    <td>@client.Name</td>
                    <td>@client.ContactDetails</td>
                    <td>@client.Region</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@client.ClientId" class="btn btn-sm btn-outline-secondary">View</a>
                        <a asp-action="Edit" asp-route-id="@client.ClientId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@client.ClientId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>