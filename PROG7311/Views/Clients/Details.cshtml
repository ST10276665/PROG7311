@model PROG7311.Models.Client
@{
    ViewData["Title"] = "Client Details";
}

<div class="page-header">
    <h2>@Model.Name</h2>
    <p>Client details and contract history</p>
</div>

<div class="card border-0 shadow-sm p-4 mb-4" style="max-width: 700px;">
    <dl class="row mb-0">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Contact Details</dt>
        <dd class="col-sm-9">@Model.ContactDetails</dd>

        <dt class="col-sm-3">Region</dt>
        <dd class="col-sm-9">@Model.Region</dd>
    </dl>
</div>

<h5 class="mb-3">Contracts</h5>
<div class="card border-0 shadow-sm">
    @if (Model.Contracts.Any())
    {
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model.Contracts)
                {
                    <tr>
                        <td>@contract.StartDate.ToShortDateString()</td>
                        <td>@contract.EndDate.ToShortDateString()</td>
                        <td>
                            <span class="badge @(contract.Status == "Active" ? "bg-success" : contract.Status == "Expired" ? "bg-danger" : contract.Status == "On Hold" ? "bg-warning text-dark" : "bg-secondary")">
                                @contract.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="p-4 text-muted small">No contracts yet for this client.</div>
    }
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-outline-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>