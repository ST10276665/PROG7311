@model PROG7311.Models.Client
@{
    ViewData["Title"] = "Delete Client";
}

<div class="page-header">
    <h2>Delete Client</h2>
    <p>Are you sure you want to delete this client?</p>
</div>

<div class="card border-0 shadow-sm p-4" style="max-width: 600px;">
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Contact Details</dt>
        <dd class="col-sm-9">@Model.ContactDetails</dd>

        <dt class="col-sm-3">Region</dt>
        <dd class="col-sm-9">@Model.Region</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ClientId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>