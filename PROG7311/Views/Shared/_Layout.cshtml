<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GLMS - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            body { display: flex; min-height: 100vh; background: #f5f5f3; }
            .sidebar { width: 220px; background: #fff; border-right: 1px solid #e5e5e5; padding: 1.5rem 0; position: fixed; height: 100vh; }
            .sidebar .logo { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid #e5e5e5; margin-bottom: 1rem; }
            .sidebar .logo h1 { font-size: 16px; font-weight: 600; margin: 0; color: #1a1a1a; }
            .sidebar .logo span { font-size: 11px; color: #999; }
            .sidebar .nav-link { display: flex; align-items: center; gap: 10px; padding: 9px 1.25rem; font-size: 13px; color: #666; border-left: 2px solid transparent; text-decoration: none; }
            .sidebar .nav-link:hover { background: #f5f5f3; color: #1a1a1a; }
            .sidebar .nav-link.active { color: #185FA5; border-left: 2px solid #185FA5; background: #f0f6fc; font-weight: 500; }
            .main-content { margin-left: 220px; flex: 1; padding: 2rem; }
            .page-header { margin-bottom: 1.5rem; }
            .page-header h2 { font-size: 20px; font-weight: 600; margin: 0 0 4px; }
            .page-header p { font-size: 13px; color: #999; margin: 0; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">
            <h1>GLMS</h1>
            <span>TechMove Logistics</span>
        </div>
        <nav>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                &#9632; Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")" asp-controller="Clients" asp-action="Index">
                &#9632; Clients
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")" asp-controller="Contracts" asp-action="Index">
                &#9632; Contracts
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequests" ? "active" : "")" asp-controller="ServiceRequests" asp-action="Index">
                &#9632; Service Requests
            </a>
            <a class="nav-link" asp-controller="Auth" asp-action="Logout">
                &#9632; Logout
            </a>
        </nav>
    </div>
    <div class="main-content">
        @RenderBody()
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>